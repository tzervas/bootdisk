{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test DevContainer",
      "type": "shell",
      "command": "./.devcontainer/test-devcontainer.sh",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Test DevContainer (Interactive)",
      "type": "shell",
      "command": "./.devcontainer/test-devcontainer.sh interactive",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Python Environment",
      "type": "shell",
      "command": "/opt/venv/bin/python --version && /opt/venv/bin/python -c 'import langchain, ollama, torch; print(\"✅ All ML packages imported successfully\")'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Rust Environment",
      "type": "shell",
      "command": "rustc --version && cargo --version && echo '✅ Rust toolchain ready'",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Ollama Service",
      "type": "shell",
      "command": "ollama serve",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Check Ollama Models",
      "type": "shell",
      "command": "ollama list",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
      {
