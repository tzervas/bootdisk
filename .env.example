# Secure environment variables for AI services
# Copy this to .env and fill in your tokens

# OpenAI API Key (optional, for premium features)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Token (optional, for private models)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Ollama Base URL (default localhost)
OLLAMA_BASE_URL=http://localhost:11434

# Development settings
DEBUG=true
LOG_LEVEL=info